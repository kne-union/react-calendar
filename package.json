{
  "name": "@kne/react-calendar",
  "version": "1.0.4",
  "description": "实现一个日程的组件",
  "syntax": {
    "esmodules": true
  },
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "types": "dist/index.d.ts",
  "source": "src/index.js",
  "scripts": {
    "init": "husky && npm run init-example",
    "start": "run-p start:lib start:md start:example",
    "build": "run-s build:lib build:md build:example",
    "init-example": "modules-dev-libs-init",
    "build:md": "npx @kne/md-doc",
    "start:md": "npx @kne/md-doc --watch",
    "build:locale": "microbundle src/locale/*.js -o dist/locale --no-compress --format modern,cjs ",
    "build:lib-main": "microbundle --no-compress --format modern,cjs --jsxImportSource react --jsx React.createElement --jsxFragment React.Fragment",
    "copy:types": "cp src/index.d.ts dist/index.d.ts",
    "build:lib": "run-s build:locale build:lib-main copy:types",
    "start:lib": "microbundle watch --no-compress --format modern,cjs --jsxImportSource react --jsx React.createElement --jsxFragment React.Fragment",
    "build:example": "cd example && npm run build",
    "start:example": "cd example && npm run start",
    "test:build": "run-s build",
    "test:lint": "eslint .",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "prettier": "prettier --config .prettierrc --write '{src/**/*,index,prompts}.{js,jsx,ts,tsx,json,css,scss}'",
    "lint-staged": "npx lint-staged"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --config .prettierrc --write",
      "git add"
    ]
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kne-union/react-calendar.git"
  },
  "keywords": [
    "react",
    "calendar",
    "schedule",
    "scheduler",
    "appointment",
    "antd",
    "dayjs"
  ],
  "author": "linzp",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kne-union/react-calendar/issues"
  },
  "homepage": "https://github.com/kne-union/react-calendar",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "dayjs": ">=1.11.0",
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@kne/microbundle": "^0.15.5",
    "@kne/modules-dev": "^2.0.33",
    "antd": "^6.4.3",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.21",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@kne/form-info": "^0.1.9",
    "@kne/react-intl": "^0.1.9",
    "@kne/use-control-value": "^0.1.9"
  }
}

